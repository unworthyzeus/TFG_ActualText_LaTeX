\contentsline {figure}{\numberline {4.2}{\ignorespaces Example Try 79 inspection panel for a Vancouver sample.}}{80}{figure.caption.106}%
\contentsline {figure}{\numberline {4.3}{\ignorespaces Try 80 validation history against frozen priors. Placeholder diagnostic, not a final test result.}}{81}{figure.caption.107}%
